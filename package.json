{
  "name": "aemeath",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "aemeath": "",
    "dev": "cross-env NODE_ENV=development LOG_FORMAT=console nodemon",
    "build": "tsup",
    "start": "cross-env NODE_ENV=production node dist/main.js",
    "worker": "cross-env NODE_ENV=production node dist/worker.js",
    "dev:frontend": "pnpm --filter frontend dev",
    "build:frontend": "pnpm --filter frontend build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"src/**/*.ts\" \"frontend/src/**/*.{ts,vue}\" \"scripts/**/*\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"frontend/src/**/*.{ts,vue}\" \"scripts/**/*\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:backend": "vitest run --project backend",
    "test:backend:watch": "vitest --project backend",
    "test:backend:coverage": "vitest run --project backend --coverage",
    "test:frontend": "vitest run --project frontend",
    "test:frontend:watch": "vitest --project frontend",
    "test:frontend:coverage": "vitest run --project frontend --coverage",
    "db:generate": "prisma generate --config prisma/main/prisma.config.ts && prisma generate --config prisma/chat/prisma.config.ts",
    "db:migrate": "prisma migrate deploy --config prisma/main/prisma.config.ts && prisma migrate deploy --config prisma/chat/prisma.config.ts",
    "db:migrate:dev:main": "prisma migrate dev --config prisma/main/prisma.config.ts",
    "db:migrate:dev:chat": "prisma migrate dev --config prisma/chat/prisma.config.ts",
    "bump": "commit-and-tag-version",
    "bump:patch": "commit-and-tag-version --release-as patch",
    "bump:minor": "commit-and-tag-version --release-as minor",
    "bump:major": "commit-and-tag-version --release-as major",
    "changelog": "commit-and-tag-version --skip.bump --skip.commit --skip.tag",
    "commit": "cz",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/websocket": "^11.2.0",
    "@langchain/openai": "^1.4.7",
    "@prisma/client": "^7.8.0",
    "@resvg/resvg-js": "^2.6.2",
    "@sinclair/typebox": "^0.34.49",
    "bullmq": "^5.78.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "langchain": "^1.4.4",
    "minio": "^8.0.7",
    "parquetjs-lite": "^0.8.7",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "commit-and-tag-version": "^12.7.3",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "{src,scripts,tests}/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/src/**/*.{ts,tsx,vue}": [
      "prettier --write"
    ]
  },
  "imports": {
    "#prisma/main": {
      "import": {
        "types": "./prisma/main/generated/index.d.ts",
        "default": "./prisma/main/generated/index.js"
      },
      "default": "./prisma/main/generated/index.js"
    },
    "#prisma/chat": {
      "import": {
        "types": "./prisma/chat/generated/index.d.ts",
        "default": "./prisma/chat/generated/index.js"
      },
      "default": "./prisma/chat/generated/index.js"
    }
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
