# ============================================================
#  Aemeath 环境变量
# ============================================================

# ── NapCat WebSocket ────────────────────────────────────────
# 必填：NapCat 认证 token，不能为空
NAPCAT_ACCESS_TOKEN=your-secret-token-here

# 消息格式：array | string
NAPCAT_MESSAGE_POST_FORMAT=array

# 是否上报自身消息
NAPCAT_REPORT_SELF_MESSAGE=false

# 心跳间隔毫秒
NAPCAT_HEART_INTERVAL=30000

# 断线重连间隔毫秒
NAPCAT_RECONNECT_INTERVAL=5000

# ── NapCat 资源 ─────────────────────────────────────────────
# 图片 URL 有效期秒数
IMAGE_URL_TTL=7200

# 是否启用 rkey 自动刷新
ENABLE_RKEY_REFRESH=true

# ── PostgreSQL ──────────────────────────────────────────────
# 主库连接 URL
DATABASE_URL=postgresql://aemeath:aemeath@localhost:5432/aemeath

# 连接池大小
DB_POOL_SIZE=10

# 聊天记录库连接 URL
CHAT_DATABASE_URL=postgresql://aemeath:aemeath@localhost:5432/chat_history

# 聊天库连接池大小
CHAT_DB_POOL_SIZE=5

# ── Redis ───────────────────────────────────────────────────
# 必填：BullMQ 任务队列 Redis URL
BULLMQ_REDIS_URL=redis://localhost:6379

# 必填：缓存 Redis URL
CACHE_REDIS_URL=redis://localhost:6380

# 持久化存储 Redis URL
PERSISTENT_REDIS_URL=redis://localhost:6379

# 缓存默认 TTL 秒数
CACHE_DEFAULT_TTL=300

# ── S3 归档（选填，不配置则禁用聊天记录 S3 归档）──────────────
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_REGION=us-east-1
# S3_ARCHIVE_BUCKET=aemeath-archive
# S3_ARCHIVE_PREFIX=chat-archive
# S3_MEDIA_BUCKET=aemeath-media
# S3_RENDER_BUCKET=aemeath-render

# ── 监控与日志 ───────────────────────────────────────────────
# 是否启用 Prometheus 指标端点
METRICS_ENABLED=true

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# 日志格式：json | console
# 本地开发建议 console
LOG_FORMAT=console

# ── 服务器 ──────────────────────────────────────────────────
# 运行环境：development | production
NODE_ENV=development

# 监听地址
HOST=0.0.0.0

# 监听端口
PORT=8000

# 前端静态文件目录
FRONTEND_DIST_DIR=frontend/dist
