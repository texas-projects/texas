// ──────────────────────────────────────────────────
// Texas — 主库 Prisma Schema
// ──────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  output          = "./generated"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════
//  Enums (PostgreSQL native ENUM types)
// ═══════════════════════════════════════════════════

/// 用户与机器人的关系等级
enum UserRelation {
  stranger
  group_member
  friend
  admin

  @@map("user_relation_enum")
}

/// 群成员角色
enum GroupRole {
  owner
  admin
  member

  @@map("group_role_enum")
}

/// 反馈类型
enum FeedbackType {
  bug
  suggestion
  complaint
  other

  @@map("feedback_type_enum")
}

/// 反馈状态
enum FeedbackStatus {
  pending
  done

  @@map("feedback_status_enum")
}

/// 反馈来源
enum FeedbackSource {
  group
  private

  @@map("feedback_source_enum")
}

/// 点赞触发来源
enum LikeSource {
  manual
  scheduled

  @@map("likesource")
}

/// 聊天归档任务状态
enum ArchiveStatus {
  pending
  exporting
  uploading
  uploaded
  partition_dropped
  completed
  failed

  @@map("archive_status_enum")
}

// ═══════════════════════════════════════════════════
//  Models
// ═══════════════════════════════════════════════════

/// 机器人已知用户表
model User {
  qq       BigInt       @id @map("qq")
  nickname String       @default("") @db.VarChar(64)
  relation UserRelation @default(stranger)

  lastSynced DateTime @default(now()) @map("last_synced") @db.Timestamptz

  // ── Relations ──
  memberships              GroupMembership[]
  feedbacks                Feedback[]           @relation("FeedbackUser")
  checkinRecords           CheckinRecord[]      @relation("CheckinUser")
  jrlpAsUser               WifeRecord[]         @relation("JrlpUser")
  jrlpAsWife               WifeRecord[]         @relation("JrlpWife")
  @@map("users")
}

/// 机器人群聊表
model Group {
  groupId        BigInt  @id @map("group_id")
  groupName      String  @default("") @map("group_name") @db.VarChar(128)
  memberCount    Int     @default(0) @map("member_count")
  maxMemberCount Int     @default(0) @map("max_member_count")
  isActive       Boolean @default(true) @map("is_active")
  botEnabled     Boolean @default(true) @map("bot_enabled")

  lastSynced DateTime @default(now()) @map("last_synced") @db.Timestamptz

  // ── Relations ──
  memberships    GroupMembership[]
  feedbacks      Feedback[]      @relation("FeedbackGroup")
  checkinRecords CheckinRecord[] @relation("CheckinGroup")
  jrlpRecords    WifeRecord[]    @relation("JrlpGroup")

  @@index([isActive])
  @@map("groups")
}

/// 群聊成员关系表
model GroupMembership {
  id              String   @id @default(uuid()) @db.Uuid
  userId          BigInt   @map("user_id")
  groupId         BigInt   @map("group_id")
  card            String   @default("") @db.VarChar(64)
  role            GroupRole @default(member)
  joinTime        BigInt   @default(0) @map("join_time")
  lastActiveTime  BigInt   @default(0) @map("last_active_time")
  title           String   @default("") @db.VarChar(64)
  titleExpireTime BigInt   @default(0) @map("title_expire_time")
  level           String   @default("") @db.VarChar(10)
  isActive        Boolean  @default(true) @map("is_active")

  // ── Relations ──
  user  User  @relation(fields: [userId], references: [qq])
  group Group @relation(fields: [groupId], references: [groupId])

  @@unique([userId, groupId], map: "uq_user_group")
  @@index([userId])
  @@index([groupId])
  @@index([isActive])
  @@map("group_memberships")
}

/// LLM 提供商表
model LlmProvider {
  id            String @id @default(uuid()) @db.Uuid
  name          String @unique @db.VarChar(64)
  apiBase       String @map("api_base") @db.VarChar(512)
  apiKey        String @map("api_key") @db.VarChar(512)
  maxRetries    Int    @default(2) @map("max_retries")
  timeout       Int    @default(60)
  retryInterval Int    @default(1) @map("retry_interval")

  // ── Relations ──
  models LlmModel[]

  @@map("llm_providers")
}

/// LLM 模型配置表
model LlmModel {
  id          String  @id @default(uuid()) @db.Uuid
  providerId  String  @map("provider_id") @db.Uuid
  modelName   String  @map("model_name") @db.VarChar(128)
  displayName String? @map("display_name") @db.VarChar(128)
  inputPrice  Decimal @default(0) @map("input_price") @db.Decimal(12, 6)
  outputPrice Decimal @default(0) @map("output_price") @db.Decimal(12, 6)
  temperature Float   @default(0.7) @db.DoublePrecision
  maxTokens   Int?    @map("max_tokens")
  forceStream Boolean @default(false) @map("force_stream")
  extraParams Json    @default("{}") @map("extra_params") @db.JsonB
  isEnabled   Boolean @default(true) @map("is_enabled")

  // ── Relations ──
  provider LlmProvider @relation(fields: [providerId], references: [id])

  @@unique([providerId, modelName], map: "uq_provider_model")
  @@index([providerId])
  @@map("llm_models")
}

/// 用户反馈表
model Feedback {
  id           String          @id @default(uuid()) @db.Uuid
  userId       BigInt          @map("user_id")
  feedbackType FeedbackType?   @map("feedback_type")
  content      String          @db.Text
  status       FeedbackStatus  @default(pending)
  adminReply   String?         @map("admin_reply") @db.Text
  source       FeedbackSource
  groupId      BigInt?         @map("group_id")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  processedAt  DateTime?       @map("processed_at") @db.Timestamptz

  // ── Relations ──
  user  User   @relation("FeedbackUser", fields: [userId], references: [qq], onDelete: Cascade)
  group Group? @relation("FeedbackGroup", fields: [groupId], references: [groupId], onDelete: SetNull)

  @@index([userId])
  @@index([feedbackType])
  @@index([status])
  @@index([groupId])
  @@map("feedbacks")
}

/// 用户群签到记录表
model CheckinRecord {
  id          Int      @id @default(autoincrement())
  groupId     BigInt   @map("group_id")
  userId      BigInt   @map("user_id")
  checkinDate DateTime @map("checkin_date") @db.Date
  checkinAt   DateTime @map("checkin_at") @db.Timestamptz

  // ── Relations ──
  group Group @relation("CheckinGroup", fields: [groupId], references: [groupId], onDelete: Cascade)
  user  User  @relation("CheckinUser", fields: [userId], references: [qq], onDelete: Cascade)

  @@unique([groupId, userId, checkinDate], map: "uq_checkin_group_user_date")
  @@index([groupId])
  @@index([checkinDate])
  @@index([userId, groupId, checkinDate], map: "idx_checkin_user_group")
  @@map("checkin")
}

/// 今日老婆抽取/预设记录表
model WifeRecord {
  id      Int      @id @default(autoincrement())
  groupId BigInt   @map("group_id")
  userId  BigInt   @map("user_id")
  wifeQq  BigInt   @map("wife_qq")
  date    DateTime @db.Date
  drawnAt DateTime? @map("drawn_at") @db.Timestamptz

  // ── Relations ──
  group Group @relation("JrlpGroup", fields: [groupId], references: [groupId], onDelete: Cascade)
  user  User  @relation("JrlpUser", fields: [userId], references: [qq], onDelete: Cascade)
  wife  User  @relation("JrlpWife", fields: [wifeQq], references: [qq], onDelete: Cascade)

  @@unique([groupId, userId, date], map: "uq_jrlp_group_user_date")
  @@index([groupId])
  @@index([userId])
  @@index([date])
  @@map("jrlp")
}

/// 定时点赞任务表
model LikeTask {
  id                Int      @id @default(autoincrement())
  qq                BigInt   @unique
  registeredAt      DateTime @default(now()) @map("registered_at") @db.Timestamptz
  registeredGroupId BigInt?  @map("registered_group_id")

  @@map("like_tasks")
}

/// 点赞执行历史记录表
model LikeHistory {
  id          Int        @id @default(autoincrement())
  qq          BigInt
  times       Int        @db.SmallInt
  triggeredAt DateTime   @default(now()) @map("triggered_at") @db.Timestamptz
  source      LikeSource
  success     Boolean

  @@index([qq, triggeredAt], map: "ix_like_history_qq_triggered_at")
  @@index([source, triggeredAt], map: "ix_like_history_source_triggered_at")
  @@map("like_history")
}

/// 漂流瓶池表
model DriftBottlePool {
  id   Int    @id
  name String @unique @db.VarChar(64)

  // ── Relations ──
  groupPools DriftBottleGroupPool[]
  items      DriftBottleItem[]

  @@map("drift_bottle_pools")
}

/// 群池映射表
model DriftBottleGroupPool {
  groupId BigInt @id @map("group_id")
  poolId  Int    @map("pool_id")

  // ── Relations ──
  pool DriftBottlePool @relation(fields: [poolId], references: [id], onDelete: Restrict)

  @@map("drift_bottle_group_pools")
}

/// 漂流瓶本体表
model DriftBottleItem {
  id            Int       @id @default(autoincrement())
  poolId        Int       @map("pool_id")
  senderId      BigInt    @map("sender_id")
  senderGroupId BigInt    @map("sender_group_id")
  content       Json      @db.JsonB
  isPicked      Boolean   @default(false) @map("is_picked")
  pickedBy      BigInt?   @map("picked_by")
  pickedAt      DateTime? @map("picked_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // ── Relations ──
  pool DriftBottlePool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId, isPicked], map: "ix_drift_bottle_items_pool_is_picked")
  @@index([senderId])
  @@map("drift_bottle_items")
}


/// 聊天记录归档日志表
model ChatArchiveLog {
  id             String        @id @default(uuid()) @db.Uuid
  partitionName  String        @unique @map("partition_name") @db.VarChar(64)
  periodStart    DateTime      @map("period_start") @db.Date
  periodEnd      DateTime      @map("period_end") @db.Date
  totalRows      BigInt        @default(0) @map("total_rows")
  originalBytes  BigInt        @default(0) @map("original_bytes")
  compressedBytes BigInt       @default(0) @map("compressed_bytes")
  s3Bucket       String        @default("") @map("s3_bucket") @db.VarChar(128)
  s3Key          String        @default("") @map("s3_key") @db.VarChar(512)
  s3Sha256       String        @default("") @map("s3_sha256") @db.VarChar(64)
  status         ArchiveStatus @default(pending)
  errorMessage   String?       @map("error_message") @db.Text
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  completedAt    DateTime?     @map("completed_at") @db.Timestamptz

  @@index([status], map: "ix_archive_log_status")
  @@index([periodStart], map: "ix_archive_log_period")
  @@map("chat_archive_log")
}
